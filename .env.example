# OpenTrust Environment
# Copy to .env and fill in your values.
# For production, set ENVIRONMENT=production and use strong secrets.
ENVIRONMENT=development

# Database
# For local dev with Docker: postgresql+asyncpg://opentrust:opentrust_dev@localhost:5432/opentrust
# For production, change the password and user accordingly
DB_URL=postgresql+asyncpg://opentrust:opentrust_dev@db:5432/opentrust

# PostgreSQL credentials (used by docker-compose.yml directly)
POSTGRES_USER=opentrust
POSTGRES_PASSWORD=opentrust_dev
POSTGRES_DB=opentrust

# Authentication
# REQUIRED. Generate with: openssl rand -hex 64
# DO NOT use "change_me" in production — API startup will fail if ENVIRONMENT=production.
JWT_SECRET=change_me

# OAuth (optional for dev)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Payment (optional for dev)
PAYMENT_PROVIDER=mock
CIRCLE_API_KEY=

# Frontend URL for CORS (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:3000

# Admin access for elevated registry endpoints (passport overwrite, revocation).
# REQUIRED in production — startup fails if empty when ENVIRONMENT=production, and
# the endpoints fail closed (503). Generate with: openssl rand -hex 32
REGISTRY_ADMIN_TOKEN=

# Rate limiting
# Format: <max_requests>/<window_seconds>
# Example: 100/60 = 100 requests per 60 seconds per IP
RATE_LIMIT=100/60

# Trusted reverse-proxy / edge IPs allowed to set X-Forwarded-For (comma-separated).
# Without this, X-Forwarded-For is ignored and the direct peer IP is used, so a
# client cannot spoof its IP to bypass rate limiting. Set to your Vercel/edge
# egress ranges in production. Note: per-instance rate limiting is best-effort on
# serverless — prefer platform-level (Vercel WAF) rate limiting for hard limits.
TRUSTED_PROXIES=

# Security headers
# Set to "1" to enable HSTS (only in production with real TLS)
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=true

# Coinbase (optional for dev)
COINBASE_BUSINESS_API_KEY_ID=
COINBASE_BUSINESS_API_KEY_SECRET=
COINBASE_BUSINESS_WEBHOOK_SECRET=
COINBASE_BUSINESS_CHECKOUT_CURRENCY=USDC
COINBASE_BUSINESS_SUCCESS_URL=http://localhost:3000/payments/success
COINBASE_BUSINESS_CANCEL_URL=http://localhost:3000/payments/cancel
