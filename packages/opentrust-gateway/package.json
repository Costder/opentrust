{
  "name": "@infinitestudios/opentrust-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "OpenTrust MCP/API gateway runtime for hosted, remote, credential-backed, and local connector tools",
  "type": "module",
  "scripts": {
    "build": "tsup src/server.ts --format esm --dts",
