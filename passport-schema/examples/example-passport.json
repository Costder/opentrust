{
  "spec_version": "0.1.0",
  "tool_identity": {
    "name": "GitHub File Search",
    "slug": "github-file-search",
    "type": "search",
    "category": "search",
    "source_url": "https://github.com/example-org/github-file-search",
    "license": "MIT",
    "maintainers": ["example-org"]
  },
  "creator_identity": {
    "creator": "Example Org",
    "organization": "Example Org",
    "github": "example-org",
    "domain": "example.dev",
    "verification_state": "github_verified"
  },
  "trust_status": "reviewer_signed",
  "revocation": { "revoked": false },
  "version_hash": {
    "version": "1.2.0",
    "commit": "a3f8c12d",
    "artifact_hash": "sha256:abc123..."
  },
  "permission_changelog": [
    {
      "from_version": "1.1.0",
      "to_version": "1.2.0",
      "added_permissions": [],
      "removed_permissions": [],
      "breaking": false,
      "notes": "Performance improvements only. No permission changes."
    }
  ],
  "capabilities": [
    "search files in a GitHub repository by name or content",
    "list directory contents",
    "read file contents at a specific ref"
  ],
  "permission_manifest": {
    "file": false,
    "terminal": false,
    "browser": false,
    "network": true,
    "memory": false,
    "wallet": false,
    "api": true,
    "camera": false,
    "microphone": false,
    "private_data": false,
    "notes": "Makes authenticated requests to the GitHub REST API only."
  },
  "data_handling": {
    "retention_days": 0,
    "stored_regions": [],
    "used_for_training": false,
    "third_party_sharing": false,
    "gdpr_compliant": true,
    "hipaa_eligible": false,
    "ccpa_compliant": true,
    "dpa_available": false,
    "privacy_policy_url": "https://example.dev/privacy"
  },
  "dependencies": [],
  "source_formats": ["mcp", "openai_function", "npm_package"],
  "format_manifests": {
    "mcp": {
      "server_command": "npx -y @example-org/github-file-search-mcp",
      "transport": "stdio",
      "config_schema": {
        "type": "object",
        "required": ["GITHUB_TOKEN"],
        "properties": {
          "GITHUB_TOKEN": { "type": "string" }
        }
      },
      "tools": [
        {
          "name": "search_files",
          "description": "Search for files in a GitHub repository",
          "inputSchema": {
            "type": "object",
            "required": ["repo", "query"],
            "properties": {
              "repo": { "type": "string", "description": "owner/repo" },
              "query": { "type": "string" }
            }
          }
        }
      ]
    },
    "openai_function": {
      "functions": [
        {
          "name": "search_github_files",
          "description": "Search for files in a GitHub repository by name or content",
          "parameters": {
            "type": "object",
            "required": ["repo", "query"],
            "properties": {
              "repo": { "type": "string" },
              "query": { "type": "string" }
            }
          }
        }
      ]
    },
    "npm_package": {
      "package_name": "@example-org/github-file-search-mcp",
      "version": "1.2.0",
      "install_command": "npm install @example-org/github-file-search-mcp"
    }
  },
  "io_schema": {
    "input": {
      "type": "object",
      "required": ["repo", "query"],
      "properties": {
        "repo": { "type": "string" },
        "query": { "type": "string" },
        "ref": { "type": "string" }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "files": {
          "type": "array",
          "items": { "type": "object", "properties": { "path": { "type": "string" }, "url": { "type": "string" } } }
        },
        "total_count": { "type": "integer" }
      }
    },
    "errors": [
      { "code": "REPO_NOT_FOUND", "description": "Repository does not exist or token lacks access.", "retryable": false },
      { "code": "RATE_LIMITED", "description": "GitHub API rate limit reached.", "retryable": true }
    ]
  },
  "caller_requirements": {
    "min_agent_trust_status": "none",
    "require_agent_identity": false
  },
  "risk_summary": {
    "ai_generated_notes": "Tool accesses GitHub API with user-provided token. Network access limited to api.github.com.",
    "human_reviewed_findings": [
      "Token passed via environment variable, not stored by the tool.",
      "No write permissions requested or used."
    ]
  },
  "review_history": [
    {
      "status": "creator_claimed",
      "timestamp": "2026-01-10T09:00:00Z",
      "reviewer": "example-org",
      "notes": "Creator claimed via GitHub OAuth."
    },
    {
      "status": "reviewer_signed",
      "timestamp": "2026-02-01T14:00:00Z",
      "reviewer": "security-reviewer-handle",
      "attestation": {
        "key_id": "security-reviewer-handle-2026-v1",
        "algorithm": "ed25519",
        "signature": "base64urlsignaturehere",
        "payload": "github-file-search:1.2.0:reviewer_signed:2026-02-01T14:00:00Z"
      },
      "notes": "Reviewed permission manifest and network access scope. No concerns."
    }
  ],
  "commercial_status": { "status": "free" },
  "security": {
    "transport": { "tls_minimum": "1.2", "hsts": true },
    "registry_signature": {
      "key_id": "opentrust-registry-2026-v1",
      "algorithm": "ed25519",
      "signature": "base64urlsignaturehere",
      "signed_at": "2026-05-14T10:00:00Z",
      "payload_hash": "sha256:examplehashhere"
    }
  },
  "cache_ttl_seconds": 86400,
  "agent_access": {
    "api_url": "https://registry.opentrust.dev/api/v1/tools/github-file-search",
    "mcp_readable": true,
    "cli_command": "opentrust inspect github-file-search",
    "rate_limits": {
      "calls_per_minute": 30,
      "calls_per_day": 5000,
      "retry_after_seconds": 60
    }
  }
}
