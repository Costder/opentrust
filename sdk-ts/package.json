{
  "name": "@infinitestudios/opentrust-client",
  "version": "1.0.2",
  "description": "TypeScript SDK for verifying and auditing MCP tool passports — OpenTrust trust registry client",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "license": "MIT",
  "homepage": "https://github.com/Costder/opentrust#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Costder/opentrust.git",
    "directory": "sdk-ts"
  },
  "bugs": {
    "url": "https://github.com/Costder/opentrust/issues"
  },
  "keywords": [
    "opentrust",
    "mcp",
    "model-context-protocol",
    "mcp-security",
    "passport",
    "trust-registry",
    "ai-agents",
    "agent-security",
    "tool-passports",
    "security-audit",
    "claude",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
