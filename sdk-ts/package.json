{
  "name": "@infinitestudios/opentrust-client",
  "version": "1.0.0",
  "description": "TypeScript SDK for the OpenTrust tool trust registry",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT",
  "homepage": "https://github.com/Costder/opentrust#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Costder/opentrust.git",
    "directory": "sdk-ts"
  },
  "bugs": {
    "url": "https://github.com/Costder/opentrust/issues"
  },
  "keywords": [
    "opentrust",
    "sdk",
    "typescript",
    "trust-registry",
    "ai-agents",
    "tool-passports"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
